{
  "expo": {
    "name": "CoupleGoAI",
    "slug": "couplegoai",
    "version": "1.0.0",
    "orientation": "portrait",
    "icon": "./assets/icon.png",
    "userInterfaceStyle": "automatic",
    "splash": {
      "image": "./assets/splash.png",
      "resizeMode": "contain",
      "backgroundColor": "#FAF5FF"
    },
    "ios": {
      "supportsTablet": false,
      "bundleIdentifier": "com.couplegoai.app",
      "infoPlist": {
        "NSCameraUsageDescription": "Used to scan your partner's QR code to connect.",
        "NSPhotoLibraryUsageDescription": "Used to share photos in chat."
      }
    },
    "android": {
      "adaptiveIcon": {
        "foregroundImage": "./assets/adaptive-icon.png",
        "backgroundColor": "#FAF5FF"
      },
      "package": "com.couplegoai.app",
      "permissions": [
        "CAMERA"
      ]
    },
    "web": {
      "favicon": "./assets/favicon.png"
    },
    "plugins": [
      [
        "expo-camera",
        {
          "cameraPermission": "Allow CoupleGoAI to access your camera to scan your partner's QR code."
        }
      ],
      "expo-secure-store"
    ],
    "scheme": "couplegoai",
    "newArchEnabled": true
  }
}
